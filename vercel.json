{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "destination": "/web/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/app",
      "destination": "/web/"
    },
    {
      "source": "/dashboard",
      "destination": "/web/"
    },
    {
      "source": "/repair",
      "destination": "/web/"
    },
    {
      "source": "/settings",
      "destination": "/web/"
    }
  ],
  "headers": [
    {
      "source": "/web/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}

# OpenClaw Agent — Environment Variables

# ─── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional ────────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-5

# Telegram (leave empty to disable)
TELEGRAM_TOKEN=

# Git settings for self-improve commits
GIT_BRANCH=main

# Working directory for agent file operations (default: current dir)
AGENT_WORKDIR=.

# Memory storage directory
MEMORY_DIR=./agent-memory

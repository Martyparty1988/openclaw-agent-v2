# OpenClaw Agent — Environment Variables
# Never commit a real .env file. Store real values in Railway Variables or your local untracked .env.

# ─── LLM provider ────────────────────────────────────────────────────────────
# anthropic = full tool-calling executor
# openai/openrouter = text-only executor in this version
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Optional OpenAI text-only mode
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional OpenRouter text-only mode
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-8b-instruct:free

# ─── Platforms ───────────────────────────────────────────────────────────────
# WhatsApp phone number without +, e.g. 420777123456
WA_PHONE_NUMBER=
DISABLE_WHATSAPP=false

# Telegram BotFather token
TELEGRAM_TOKEN=
DISABLE_TELEGRAM=false

# ─── Access control ──────────────────────────────────────────────────────────
# Recommended: keep ALLOW_ALL_USERS=false and set at least one allowlist.
ALLOW_ALL_USERS=false
ALLOWED_USER_IDS=
ALLOWED_TELEGRAM_CHAT_IDS=
ALLOWED_WHATSAPP_NUMBERS=

# ─── Agent tool safety ───────────────────────────────────────────────────────
# Keep false unless this is a trusted private deployment.
ALLOW_AGENT_BASH=false
ALLOW_AGENT_WRITE=false
ALLOWED_FETCH_HOSTS=

# ─── Git settings ────────────────────────────────────────────────────────────
GIT_BRANCH=main
GITHUB_REPO=Martyparty1988/openclaw-agent-v2
GIT_TOKEN=

# ─── Paths ───────────────────────────────────────────────────────────────────
AGENT_WORKDIR=.
WEB_DIR=./web
MEMORY_DIR=./agent-memory

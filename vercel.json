{
  "buildCommand": "echo 'Static Martybot web - no build needed'",
  "installCommand": "echo 'No install needed for static web'",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "destination": "/web/index.html",
      "permanent": false
    },
    {
      "source": "/web/",
      "destination": "/web/index.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/app",
      "destination": "/web/index.html"
    },
    {
      "source": "/dashboard",
      "destination": "/web/index.html"
    },
    {
      "source": "/repair",
      "destination": "/web/index.html"
    },
    {
      "source": "/settings",
      "destination": "/web/index.html"
    }
  ],
  "headers": [
    {
      "source": "/web/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
